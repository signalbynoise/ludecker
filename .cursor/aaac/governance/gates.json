{
  "version": 1,
  "description": "Governance gates — approval/checkpoints, not work phases. Composed into runtime after plan, before execute.",
  "stacks": {
    "pre_execute": [
      "validate",
      "impact_analysis",
      "dependency_graph",
      "fitness_functions",
      "rollback"
    ],
    "pre_execute_minimal": [
      "validate",
      "impact_analysis",
      "dependency_graph",
      "fitness_functions"
    ],
    "release": ["validate"]
  },
  "gate_rules": {
    "rollback": {
      "required_when": ["object_maturity:protected", "impact.blast_radius:high"]
    },
    "human_approval": {
      "trigger_when": [
        "confidence below threshold",
        "fitness fail on security or layer_boundaries or minimal_complexity",
        "complexity score above verb threshold",
        "plan missing requirement_map or unjustified create",
        "impact proceed false",
        "rollback unverified",
        "user intent contains requires approval",
        "capability runtime require_approval",
        "capability state deprecated"
      ],
      "run_fields": {
        "status": "blocked",
        "awaiting_approval": true,
        "blocked_reason": "string"
      }
    }
  }
}
